# ─── Database ────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────
AUTH_SECRET="CHANGE_ME_TO_RANDOM_SECRET"
AUTH_URL="http://localhost:3000"

# ─── Paymob (planned integration) ────────────────────
# Hosted checkout flow uses the public key in the checkout URL and a client secret returned by the server-side intention flow.
PAYMOB_PUBLIC_KEY="pk_live_or_test"
PAYMOB_SECRET_KEY="sk_live_or_test"
PAYMOB_INTEGRATION_ID="123456"
PAYMOB_HMAC_SECRET="change_me"

# ─── WATI (planned integration) ──────────────────────
# WATI will be used for WhatsApp template delivery, checkout-button templates, and message-status webhooks.
WATI_API_BASE_URL="https://your-wati-host"
WATI_ACCESS_TOKEN="change_me"
WATI_WEBHOOK_SECRET="change_me"
