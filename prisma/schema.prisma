generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentLinkStatus {
  active
  expired
  paid
  failed
}

enum ProviderConnectionStatus {
  draft
  configured
  verified
  errored
  disabled
}

enum ProviderConnectionMode {
  sandbox
  live
}

enum MessagingProviderKind {
  wati
}

enum PaymentProviderKind {
  paymob
}

enum PaymentEventType {
  callback_received
  payment_succeeded
  payment_failed
  callback_rejected
  manual_mark_paid
}

enum ReminderRunStatus {
  scheduled
  sending
  sent
  delivered
  failed
  suppressed
  cancelled
}

enum DeliveryAttemptStatus {
  started
  succeeded
  failed
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  businessName   String?
  whatsappNumber String?
  plan           String    @default("free")
  notifyPaymentReceived Boolean @default(true)
  notifyDailySummary Boolean @default(true)
  notifyOverdueAlerts Boolean @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  clients   Client[]
  reminders ReminderTemplate[]
  paymentLinks PaymentLink[]
  paymentEvents PaymentEvent[]
  reminderRuns ReminderRun[]
  messagingProviderConnections MessagingProviderConnection[]
  paymentProviderConnections PaymentProviderConnection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([userId])
  @@unique([userId, phone])
}

model Invoice {
  id        String   @id @default(cuid())
  invoiceNo String
  clientId  String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  dueDate   DateTime
  status    String   @default("pending")
  paidAt    DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  events InvoiceEvent[]
  paymentLinks PaymentLink[]
  paymentEvents PaymentEvent[]
  reminderRuns ReminderRun[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@unique([userId, invoiceNo])
}

model InvoiceEvent {
  id        String   @id @default(cuid())
  invoiceId String
  userId    String
  type      String
  message   String
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model ReminderTemplate {
  id                   String  @id @default(cuid())
  userId               String
  channel              String
  timing               String
  template             String  @db.Text
  providerTemplateName String?
  active               Boolean @default(true)
  order                Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderRuns ReminderRun[]

  @@index([userId])
}

model MessagingProviderConnection {
  id                String                   @id @default(cuid())
  userId            String
  provider          MessagingProviderKind
  mode              ProviderConnectionMode   @default(sandbox)
  status            ProviderConnectionStatus @default(draft)
  accountLabel      String?
  senderIdentifier  String?
  encryptedConfig   String                   @db.Text
  verifiedAt        DateTime?
  lastHealthcheckAt DateTime?
  lastError         String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderRuns ReminderRun[]

  @@unique([userId, provider])
  @@index([userId, status])
}

model PaymentProviderConnection {
  id                String                   @id @default(cuid())
  userId            String
  provider          PaymentProviderKind
  mode              ProviderConnectionMode   @default(sandbox)
  status            ProviderConnectionStatus @default(draft)
  accountLabel      String?
  encryptedConfig   String                   @db.Text
  verifiedAt        DateTime?
  lastHealthcheckAt DateTime?
  lastError         String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentLinks  PaymentLink[]
  paymentEvents PaymentEvent[]

  @@unique([userId, provider])
  @@index([userId, status])
}

model PaymentLink {
  id                   String            @id @default(cuid())
  invoiceId            String
  userId               String
  provider             String
  providerRef          String?
  providerConnectionId String?
  url                  String
  status               PaymentLinkStatus @default(active)
  isPrimary            Boolean           @default(true)
  expiresAt            DateTime?
  rawPayload           Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  invoice            Invoice                    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConnection PaymentProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@index([invoiceId, provider])
  @@index([userId, status])
  @@index([providerConnectionId, status])
}

model PaymentEvent {
  id                   String                     @id @default(cuid())
  invoiceId             String
  userId                String
  provider              String
  providerEventId       String
  providerConnectionId  String?
  type                  PaymentEventType
  amount                Decimal                   @db.Decimal(12, 2)
  currency              String
  rawPayload            Json?
  createdAt             DateTime                  @default(now())

  invoice            Invoice                    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConnection PaymentProviderConnection? @relation(fields: [providerConnectionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([invoiceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model ReminderRun {
  id                   String            @id @default(cuid())
  invoiceId            String
  templateId           String?
  userId               String
  channel              String
  timingLabel          String
  templateSnapshot     String            @db.Text
  scheduledFor         DateTime
  status               ReminderRunStatus @default(scheduled)
  providerMessageId     String?
  messagingConnectionId String?
  deliveryConfirmedAt   DateTime?
  sentAt                DateTime?
  lastError             String?
  suppressionReason     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  invoice             Invoice                     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  template            ReminderTemplate?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messagingConnection MessagingProviderConnection? @relation(fields: [messagingConnectionId], references: [id], onDelete: SetNull)
  attempts            DeliveryAttempt[]

  @@index([invoiceId, scheduledFor])
  @@index([userId, status, scheduledFor])
}

model DeliveryAttempt {
  id               String                @id @default(cuid())
  reminderRunId    String
  attemptNo        Int
  status           DeliveryAttemptStatus
  providerResponse Json?
  errorMessage     String?
  createdAt        DateTime              @default(now())

  reminderRun ReminderRun @relation(fields: [reminderRunId], references: [id], onDelete: Cascade)

  @@unique([reminderRunId, attemptNo])
  @@index([reminderRunId, createdAt(sort: Desc)])
}
